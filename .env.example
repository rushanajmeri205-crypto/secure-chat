# Database
DATABASE_URL=postgresql://securechat:securechat@localhost:5432/securechat

# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string-in-production
CLIENT_URL=http://localhost:5173

# Bootstrap admin (created on first seed if no admin exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Media
UPLOAD_DIR=./uploads
MEDIA_TOKEN_SECRET=change-me-media-token-secret
